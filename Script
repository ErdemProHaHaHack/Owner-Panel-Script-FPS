-- [[ CORE LOGIC ]] --

local function isVisible(targetPart)
    if not Settings.CheckVisibility then return true end
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin).Unit * (targetPart.Position - origin).Magnitude
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {Player.Character, targetPart.Parent}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local result = game.Workspace:Raycast(origin, direction, raycastParams)
    return result == nil
end

local function getClosestTarget()
    local closestTarget = nil
    local shortestDistance = math.huge
    for _, obj in pairs(game.Workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health > 0 and obj.Parent:FindFirstChild("Head") and obj.Parent ~= Player.Character then
            local targetHead = obj.Parent.Head
            if not Settings.TargetBots and not game.Players:GetPlayerFromCharacter(obj.Parent) then continue end
            local distance = (targetHead.Position - Camera.CFrame.Position).Magnitude
            if distance < shortestDistance then
                if isVisible(targetHead) then
                    shortestDistance = distance
                    closestTarget = targetHead
                end
            end
        end
    end
    return closestTarget
end

local bv, bg
RunService.RenderStepped:Connect(function()
    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    local hum = char:FindFirstChildOfClass("Humanoid")

    -- Camlock
    if Settings.CamlockEnabled then
        local target = getClosestTarget()
        if target then Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position) end
    end

    -- Speed & Jump
    if hum then
        hum.WalkSpeed = Settings.SpeedEnabled and Settings.WalkSpeed or 16
        hum.JumpPower = Settings.JumpEnabled and Settings.JumpPower or 50
    end

    -- FIXED FLY SYSTEM
    if Settings.FlyEnabled then
        if not bv then
            bv = Instance.new("BodyVelocity", root)
            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bg = Instance.new("BodyGyro", root)
            bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        end
        if hum then hum.PlatformStand = true end -- This prevents the fly from stopping
        bv.Velocity = Camera.CFrame.LookVector * Settings.FlySpeed
        bg.CFrame = Camera.CFrame
    else
        if bv then bv:Destroy() bv = nil end
        if bg then bg:Destroy() bg = nil end
        if hum then hum.PlatformStand = false end
    end
end)

UserInputService.JumpRequest:Connect(function()
